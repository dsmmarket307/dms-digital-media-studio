"use client";
import { useState, useEffect } from "react";
import { createClient } from "@/lib/supabase/client";
import { useRouter } from "next/navigation";
import Image from "next/image";

const ESTADO_COLORS: Record<string, string> = {
  pendiente: "#F59E0B",
  en_proceso: "#3B82F6",
  revision: "#8B5CF6",
  entregado: "#10B981",
  cancelado: "#EF4444",
};

const ESTADOS = ["pendiente", "en_proceso", "revision", "entregado", "cancelado"];

export default function AdminDashboard() {
  const router = useRouter();
  const supabase = createClient();
  const [loading, setLoading] = useState(true);
  const [clientes, setClientes] = useState<any[]>([]);
  const [proyectos, setProyectos] = useState<any[]>([]);
  const [pagos, setPagos] = useState<any[]>([]);
  const [leads, setLeads] = useState<any[]>([]);
  const [tab, setTab] = useState<"proyectos" | "clientes" | "pagos" | "leads" | "ventas" | "sitios">("proyectos");
  const [ventas, setVentas] = useState<any[]>([]);
  const [sitios, setSitios] = useState<any[]>([]);
  const [editando, setEditando] = useState<any>(null);
  const [saving, setSaving] = useState(false);

  useEffect(() => {
    async function load() {
      const { data: { user } } = await supabase.auth.getUser();
      if (!user) { router.push("/auth/login"); return; }
      const { data: prof } = await supabase.from("profiles").select("role").eq("id", user.id).single();
      if (prof?.role !== "admin") { router.push("/dashboard/client"); return; }
      const [{ data: c }, { data: p }, { data: pags }, { data: l }, { data: v }, { data: s }] = await Promise.all([
        supabase.from("profiles").select("*").eq("role", "client").order("created_at", { ascending: false }),
        supabase.from("proyectos").select("*, profiles(name, email)").order("created_at", { ascending: false }),
        supabase.from("pagos").select("*, profiles(name)").order("created_at", { ascending: false }),
        supabase.from("leads").select("*").order("created_at", { ascending: false }),
        supabase.from("package_orders").select("*").order("created_at", { ascending: false }),
        supabase.from("generated_websites").select("*").order("created_at", { ascending: false }),
      ]);
      setClientes(c ?? []);
      setProyectos(p ?? []);
      setPagos(pags ?? []);
      setLeads(l ?? []);
      setVentas(v ?? []);
      setSitios(s ?? []);
      setLoading(false);
    }
    load();
  }, []);

  async function handleLogout() {
    await supabase.auth.signOut();
    router.push("/auth/login");
  }

  async function saveProyecto() {
    if (!editando) return;
    setSaving(true);
    await supabase.from("proyectos").update({
      estado: editando.estado,
      progreso: parseInt(editando.progreso),
      notas: editando.notas,
      fecha_entrega: editando.fecha_entrega,
    }).eq("id", editando.id);
    setProyectos(prev => prev.map(p => p.id === editando.id ? { ...p, ...editando } : p));
    setEditando(null);
    setSaving(false);
  }

  async function crearProyecto(clientId: string) {
    const nombre = prompt("Nombre del proyecto:");
    if (!nombre) return;
    const plan = prompt("Plan (Basico, Profesional, Empresarial):");
    if (!plan) return;
    const precio = prompt("Precio:");
    await supabase.from("proyectos").insert({
      client_id: clientId,
      nombre,
      plan,
      precio: precio ? parseFloat(precio) : null,
      estado: "pendiente",
      progreso: 0,
    });
    const { data } = await supabase.from("proyectos").select("*, profiles(name, email)").order("created_at", { ascending: false });
    setProyectos(data ?? []);
  }

  if (loading) return (
    <div className="min-h-screen bg-white flex items-center justify-center">
      <div style={{ width: 40, height: 40, border: "3px solid #e9d5ff", borderTopColor: "#7c3aed", borderRadius: "50%", animation: "spin 0.8s linear infinite" }} />
      <style>{`@keyframes spin { to { transform: rotate(360deg); } }`}</style>
    </div>
  );

  const totalIngresos = pagos.filter(p => p.estado === "pagado").reduce((s, p) => s + Number(p.monto), 0);

  return (
    <div className="min-h-screen bg-gray-50">
      <style>{`@keyframes spin { to { transform: rotate(360deg); } }`}</style>

      {/* NAVBAR */}
      <header className="bg-white border-b border-gray-200 sticky top-0 z-50">
        <div className="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
          <div className="flex items-center gap-3">
            <Image src="/logo-dms.png" alt="DMS" width={120} height={38} />
            <span className="text-xs bg-purple-100 text-purple-700 font-semibold px-3 py-1 rounded-full">Admin</span>
          </div>
          <button onClick={handleLogout} className="text-sm text-gray-500 hover:text-red-500 transition-colors">Cerrar sesion</button>
          <a href="/dashboard/admin/ai-builder" className="text-sm bg-purple-600 text-white px-4 py-2 rounded-lg font-semibold hover:bg-purple-700 transition-colors">AI Builder</a>
        </div>
      </header>

      <main className="max-w-7xl mx-auto px-6 py-10">

        {/* STATS */}
        <div className="grid md:grid-cols-4 gap-6 mb-10">
          {[
            { label: "Clientes", value: clientes.length, color: "#7c3aed" },
            { label: "Proyectos", value: proyectos.length, color: "#3B82F6" },
            { label: "Leads", value: leads.length, color: "#F59E0B" },
            { label: "Ingresos", value: `$${totalIngresos.toLocaleString("es-CO")}`, color: "#10B981" },
          ].map(s => (
            <div key={s.label} className="bg-white rounded-xl border border-gray-100 p-6 shadow-sm">
              <p className="text-3xl font-bold" style={{ color: s.color }}>{s.value}</p>
              <p className="text-sm text-gray-500 mt-1">{s.label}</p>
            </div>
          ))}
        </div>

        {/* TABS */}
        <div className="flex gap-2 mb-6 border-b border-gray-200">
          {(["proyectos", "clientes", "pagos", "leads", "ventas", "sitios"] as const).map(t => (
            <button key={t} onClick={() => setTab(t)} className="px-4 py-2 text-sm font-semibold capitalize transition-colors" style={{ borderBottom: tab === t ? "2px solid #7c3aed" : "2px solid transparent", color: tab === t ? "#7c3aed" : "#6b7280" }}>
              {t}
            </button>
          ))}
        </div>

        {/* PROYECTOS */}
        {tab === "proyectos" && (
          <div className="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden">
            <table className="w-full text-sm">
              <thead className="bg-gray-50 border-b border-gray-100">
                <tr>
                  {["Cliente", "Proyecto", "Plan", "Estado", "Progreso", "Acciones"].map(h => (
                    <th key={h} className="text-left px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">{h}</th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {proyectos.map(p => (
                  <tr key={p.id} className="border-b border-gray-50 hover:bg-gray-50 transition-colors">
                    <td className="px-6 py-4 text-gray-700">{p.profiles?.name ?? "---"}</td>
                    <td className="px-6 py-4 font-semibold text-gray-900">{p.nombre}</td>
                    <td className="px-6 py-4 text-gray-500">{p.plan}</td>
                    <td className="px-6 py-4">
                      <span className="text-xs font-semibold px-3 py-1 rounded-full" style={{ background: `${ESTADO_COLORS[p.estado]}22`, color: ESTADO_COLORS[p.estado] }}>
                        {p.estado.replace("_", " ")}
                      </span>
                    </td>
                    <td className="px-6 py-4">
                      <div className="flex items-center gap-2">
                        <div className="w-20 bg-gray-100 rounded-full h-2">
                          <div className="bg-purple-600 h-2 rounded-full" style={{ width: `${p.progreso ?? 0}%` }} />
                        </div>
                        <span className="text-xs text-gray-500">{p.progreso ?? 0}%</span>
                      </div>
                    </td>
                    <td className="px-6 py-4">
                      <button onClick={() => setEditando({ ...p })} className="text-xs bg-purple-600 text-white px-3 py-1 rounded-lg hover:bg-purple-700 transition-colors">
                        Editar
                      </button>
                    </td>
                  </tr>
                ))}
                {proyectos.length === 0 && (
                  <tr><td colSpan={6} className="px-6 py-10 text-center text-gray-400">No hay proyectos</td></tr>
                )}
              </tbody>
            </table>
          </div>
        )}

        {/* CLIENTES */}
        {tab === "clientes" && (
          <div className="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden">
            <table className="w-full text-sm">
              <thead className="bg-gray-50 border-b border-gray-100">
                <tr>
                  {["Nombre", "Email", "Fecha registro", "Acciones"].map(h => (
                    <th key={h} className="text-left px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">{h}</th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {clientes.map(c => (
                  <tr key={c.id} className="border-b border-gray-50 hover:bg-gray-50 transition-colors">
                    <td className="px-6 py-4 font-semibold text-gray-900">{c.name ?? "Sin nombre"}</td>
                    <td className="px-6 py-4 text-gray-600">{c.email}</td>
                    <td className="px-6 py-4 text-gray-500">{new Date(c.created_at).toLocaleDateString("es-CO")}</td>
                    <td className="px-6 py-4">
                      <button onClick={() => crearProyecto(c.id)} className="text-xs bg-purple-600 text-white px-3 py-1 rounded-lg hover:bg-purple-700 transition-colors">
                        + Proyecto
                      </button>
                    </td>
                  </tr>
                ))}
                {clientes.length === 0 && (
                  <tr><td colSpan={4} className="px-6 py-10 text-center text-gray-400">No hay clientes</td></tr>
                )}
              </tbody>
            </table>
          </div>
        )}

        {/* PAGOS */}
        {tab === "pagos" && (
          <div className="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden">
            <table className="w-full text-sm">
              <thead className="bg-gray-50 border-b border-gray-100">
                <tr>
                  {["Cliente", "Monto", "Metodo", "Estado", "Fecha"].map(h => (
                    <th key={h} className="text-left px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">{h}</th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {pagos.map(p => (
                  <tr key={p.id} className="border-b border-gray-50 hover:bg-gray-50 transition-colors">
                    <td className="px-6 py-4 text-gray-700">{p.profiles?.name ?? "---"}</td>
                    <td className="px-6 py-4 font-semibold text-gray-900">${Number(p.monto).toLocaleString("es-CO")}</td>
                    <td className="px-6 py-4 text-gray-500">{p.metodo ?? "---"}</td>
                    <td className="px-6 py-4">
                      <span className="text-xs font-semibold px-3 py-1 rounded-full" style={{ background: p.estado === "pagado" ? "#10b98122" : "#f59e0b22", color: p.estado === "pagado" ? "#10B981" : "#F59E0B" }}>
                        {p.estado}
                      </span>
                    </td>
                    <td className="px-6 py-4 text-gray-500">{new Date(p.created_at).toLocaleDateString("es-CO")}</td>
                  </tr>
                ))}
                {pagos.length === 0 && (
                  <tr><td colSpan={5} className="px-6 py-10 text-center text-gray-400">No hay pagos</td></tr>
                )}
              </tbody>
            </table>
          </div>
        )}

        {/* LEADS */}
        {tab === "leads" && (
          <div className="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden">
            <table className="w-full text-sm">
              <thead className="bg-gray-50 border-b border-gray-100">
                <tr>
                  {["Nombre", "Email", "Telefono", "Mensaje", "Fecha"].map(h => (
                    <th key={h} className="text-left px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">{h}</th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {leads.map(l => (
                  <tr key={l.id} className="border-b border-gray-50 hover:bg-gray-50 transition-colors">
                    <td className="px-6 py-4 font-semibold text-gray-900">{l.nombre}</td>
                    <td className="px-6 py-4 text-gray-600">{l.email}</td>
                    <td className="px-6 py-4 text-gray-500">{l.telefono ?? "---"}</td>
                    <td className="px-6 py-4 text-gray-500 max-w-xs truncate">{l.mensaje ?? "---"}</td>
                    <td className="px-6 py-4 text-gray-500">{new Date(l.created_at).toLocaleDateString("es-CO")}</td>
                  </tr>
                ))}
                {leads.length === 0 && (
                  <tr><td colSpan={5} className="px-6 py-10 text-center text-gray-400">No hay leads</td></tr>
                )}
              </tbody>
            </table>
          </div>
        )}
      </main>
        {/* SITIOS */}
        {tab === "sitios" && (
          <div className="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden">
            <table className="w-full text-sm">
              <thead className="bg-gray-50 border-b border-gray-100">
                <tr>
                  {["Proyecto", "Tipo", "Cliente", "Estado", "Prueba", "Fecha"].map(h => (
                    <th key={h} className="text-left px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">{h}</th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {sitios.map(s => {
                  const daysLeft = s.trial_ends_at ? Math.ceil((new Date(s.trial_ends_at).getTime() - new Date().getTime()) / (1000 * 60 * 60 * 24)) : null;
                  return (
                    <tr key={s.id} className="border-b border-gray-50 hover:bg-gray-50 transition-colors">
                      <td className="px-6 py-4 font-semibold text-gray-900">{s.project_name}</td>
                      <td className="px-6 py-4 text-gray-500">{s.website_type}</td>
                      <td className="px-6 py-4 text-gray-600">{s.client_email ?? "---"}</td>
                      <td className="px-6 py-4">
                        <span className="text-xs font-semibold px-3 py-1 rounded-full" style={{ background: s.status === "activo" ? "#10b98122" : s.status === "demo" ? "#7c3aed22" : "#f59e0b22", color: s.status === "activo" ? "#10B981" : s.status === "demo" ? "#7c3aed" : "#F59E0B" }}>
                          {s.status}
                        </span>
                      </td>
                      <td className="px-6 py-4 text-gray-500">
                        {daysLeft !== null ? (daysLeft > 0 ? `${daysLeft} dias` : "Expirado") : "---"}
                      </td>
                      <td className="px-6 py-4 text-gray-500">{new Date(s.created_at).toLocaleDateString("es-CO")}</td>
                    </tr>
                  );
                })}
                {sitios.length === 0 && (
                  <tr><td colSpan={6} className="px-6 py-10 text-center text-gray-400">No hay sitios generados</td></tr>
                )}
              </tbody>
            </table>
          </div>
        )}
        {/* VENTAS */}
        {tab === "ventas" && (
          <div className="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden">
            <table className="w-full text-sm">
              <thead className="bg-gray-50 border-b border-gray-100">
                <tr>
                  {["Cliente", "Correo", "Paquete", "Valor", "Estado", "ID Pago", "Fecha"].map(h => (
                    <th key={h} className="text-left px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">{h}</th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {ventas.map(v => (
                  <tr key={v.id} className="border-b border-gray-50 hover:bg-gray-50 transition-colors">
                    <td className="px-6 py-4 font-semibold text-gray-900">{v.customer_name}</td>
                    <td className="px-6 py-4 text-gray-600">{v.customer_email}</td>
                    <td className="px-6 py-4 text-gray-600">{v.package_name}</td>
                    <td className="px-6 py-4 font-semibold text-gray-900">${Number(v.price).toLocaleString("es-CO")}</td>
                    <td className="px-6 py-4">
                      <span className="text-xs font-semibold px-3 py-1 rounded-full" style={{ background: v.status === "approved" ? "#10b98122" : "#f59e0b22", color: v.status === "approved" ? "#10B981" : "#F59E0B" }}>
                        {v.status}
                      </span>
                    </td>
                    <td className="px-6 py-4 text-gray-400 text-xs">{v.mercadopago_payment_id ?? "---"}</td>
                    <td className="px-6 py-4 text-gray-500">{new Date(v.created_at).toLocaleDateString("es-CO")}</td>
                  </tr>
                ))}
                {ventas.length === 0 && (
                  <tr><td colSpan={7} className="px-6 py-10 text-center text-gray-400">No hay ventas registradas</td></tr>
                )}
              </tbody>
            </table>
          </div>
        )}

      {/* MODAL EDITAR PROYECTO */}
      {editando && (
        <div className="fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center px-4">
          <div className="bg-white rounded-2xl p-8 max-w-md w-full shadow-xl">
            <h2 className="text-xl font-bold text-gray-900 mb-6">Editar proyecto</h2>
            <div className="space-y-4">
              <div>
                <label className="block text-sm font-medium text-gray-700 mb-1">Estado</label>
                <select value={editando.estado} onChange={e => setEditando({ ...editando, estado: e.target.value })} className="w-full border border-gray-300 rounded-lg p-3 text-sm focus:outline-none focus:border-purple-600">
                  {ESTADOS.map(s => <option key={s} value={s}>{s.replace("_", " ")}</option>)}
                </select>
              </div>
              <div>
                <label className="block text-sm font-medium text-gray-700 mb-1">Progreso ({editando.progreso}%)</label>
                <input type="range" min="0" max="100" value={editando.progreso ?? 0} onChange={e => setEditando({ ...editando, progreso: e.target.value })} className="w-full accent-purple-600" />
              </div>
              <div>
                <label className="block text-sm font-medium text-gray-700 mb-1">Fecha de entrega</label>
                <input type="date" value={editando.fecha_entrega ?? ""} onChange={e => setEditando({ ...editando, fecha_entrega: e.target.value })} className="w-full border border-gray-300 rounded-lg p-3 text-sm focus:outline-none focus:border-purple-600" />
              </div>
              <div>
                <label className="block text-sm font-medium text-gray-700 mb-1">Notas internas</label>
                <textarea value={editando.notas ?? ""} onChange={e => setEditando({ ...editando, notas: e.target.value })} rows={3} className="w-full border border-gray-300 rounded-lg p-3 text-sm focus:outline-none focus:border-purple-600" />
              </div>
            </div>
            <div className="flex gap-3 mt-6">
              <button onClick={() => setEditando(null)} className="flex-1 border border-gray-300 py-3 rounded-lg text-sm font-semibold hover:bg-gray-50 transition-colors">Cancelar</button>
              <button onClick={saveProyecto} disabled={saving} className="flex-1 bg-purple-600 text-white py-3 rounded-lg text-sm font-semibold hover:bg-purple-700 transition-colors disabled:opacity-50">
                {saving ? "Guardando..." : "Guardar"}
              </button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}

