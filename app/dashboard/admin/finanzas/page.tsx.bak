"use client";
import { useState, useEffect } from "react";
import { createClient } from "@/lib/supabase/client";
import { BarChart, Bar, LineChart, Line, XAxis, YAxis, CartesianGrid, Tooltip, ResponsiveContainer } from "recharts";

const supabase = createClient();
const fmt = (n: number) => new Intl.NumberFormat("es-CO", { style: "currency", currency: "COP", maximumFractionDigits: 0 }).format(n);

export default function FinanzasPage() {
  const [loading, setLoading] = useState(true);
  const [pagos, setPagos] = useState<any[]>([]);
  const [ventas, setVentas] = useState<any[]>([]);
  const [error, setError] = useState("");

  useEffect(() => {
    async function load() {
      try {
        const [{ data: p }, { data: v }] = await Promise.all([
          supabase.from("pagos").select("*").order("created_at", { ascending: false }),
          supabase.from("package_orders").select("*").order("created_at", { ascending: false }),
        ]);
        setPagos(p ?? []);
        setVentas(v ?? []);
      } catch { setError("Error cargando datos"); }
      finally { setLoading(false); }
    }
    load();
  }, []);

  const totalIngresos = pagos.filter(p => p.estado === "pagado").reduce((s, p) => s + Number(p.monto), 0);
  const totalVentas = ventas.filter(v => v.status === "approved").reduce((s, v) => s + Number(v.price), 0);
  const totalGeneral = totalIngresos + totalVentas;
  const pendiente = pagos.filter(p => p.estado !== "pagado").reduce((s, p) => s + Number(p.monto), 0);

  const meses = ["Ene", "Feb", "Mar", "Abr", "May", "Jun", "Jul", "Ago", "Sep", "Oct", "Nov", "Dic"];
  const chartData = meses.map((mes, i) => {
    const ingresos = pagos.filter(p => p.estado === "pagado" && new Date(p.created_at).getMonth() === i).reduce((s, p) => s + Number(p.monto), 0);
    const paquetes = ventas.filter(v => v.status === "approved" && new Date(v.created_at).getMonth() === i).reduce((s, v) => s + Number(v.price), 0);
    return { mes, ingresos, paquetes, total: ingresos + paquetes };
  }).slice(0, new Date().getMonth() + 1);

  const card = (label: string, value: string, color: string, sub?: string) => (
    <div style={{ background: "#fff", borderRadius: 16, border: "1px solid rgba(124,58,237,0.1)", padding: "20px 24px", flex: 1, minWidth: 180 }}>
      <div style={{ width: 42, height: 42, borderRadius: 10, background: "rgba(124,58,237,0.08)", display: "flex", alignItems: "center", justifyContent: "center", marginBottom: 12 }}>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke={color} strokeWidth="1.5"><circle cx="12" cy="12" r="10"/></svg>
      </div>
      <p style={{ color: "#555", fontSize: 11, fontWeight: 600, textTransform: "uppercase", letterSpacing: "0.8px", margin: "0 0 8px" }}>{label}</p>
      <p style={{ color, fontSize: 24, fontWeight: 800, margin: "0 0 4px" }}>{value}</p>
      {sub && <p style={{ color: "#999", fontSize: 12, margin: 0 }}>{sub}</p>}
    </div>
  );

  return (
    <div style={{ minHeight: "100vh", background: "#f5f5f5", padding: "2.5rem 2rem", fontFamily: "Inter, system-ui, sans-serif" }}>
      <div style={{ maxWidth: 1100, margin: "0 auto" }}>

        <div style={{ marginBottom: "2rem", paddingBottom: "1.5rem", borderBottom: "1px solid rgba(124,58,237,0.15)", display: "flex", justifyContent: "space-between", alignItems: "flex-end", flexWrap: "wrap", gap: "1rem" }}>
          <div>
            <a href="/dashboard/admin" style={{ fontSize: "0.75rem", color: "#999", textDecoration: "none" }}>← Dashboard</a>
            <p style={{ fontSize: "0.65rem", letterSpacing: "3px", textTransform: "uppercase", color: "#7c3aed", margin: "0.75rem 0 0.25rem", fontWeight: 600 }}>Administrador</p>
            <h1 style={{ fontSize: "1.75rem", fontWeight: 800, color: "#111", margin: 0 }}>Finanzas del Negocio</h1>
            <p style={{ color: "#555", fontSize: 13, margin: "6px 0 0" }}>Resumen financiero de DMS Digital Studio</p>
          </div>
          <button onClick={() => { setLoading(true); setTimeout(() => setLoading(false), 500); }} style={{ background: "rgba(124,58,237,0.08)", border: "1px solid rgba(124,58,237,0.2)", color: "#7c3aed", borderRadius: 8, padding: "8px 16px", fontSize: 13, fontWeight: 600, cursor: "pointer" }}>Actualizar</button>
        </div>

        {error && <div style={{ marginBottom: 20, padding: "12px 16px", background: "rgba(239,68,68,0.08)", border: "1px solid rgba(239,68,68,0.25)", borderRadius: 10, color: "#ef4444", fontSize: 13 }}>{error}</div>}

        {loading ? (
          <div style={{ textAlign: "center", padding: 80 }}>
            <div style={{ width: 40, height: 40, border: "3px solid #ede9fe", borderTopColor: "#7c3aed", borderRadius: "50%", animation: "spin 0.8s linear infinite", margin: "0 auto" }} />
            <style>{`@keyframes spin { to { transform: rotate(360deg); } }`}</style>
          </div>
        ) : (
          <>
            <div style={{ display: "flex", gap: 14, marginBottom: 14, flexWrap: "wrap" }}>
              {card("Ingresos Proyectos", fmt(totalIngresos), "#7c3aed", `${pagos.filter(p => p.estado === "pagado").length} pagos`)}
              {card("Ventas Paquetes", fmt(totalVentas), "#7c3aed", `${ventas.filter(v => v.status === "approved").length} ventas`)}
              {card("Total General", fmt(totalGeneral), "#059669")}
              {card("Por Cobrar", fmt(pendiente), "#f59e0b", "Pagos pendientes")}
            </div>

            <div style={{ background: "#fff", borderRadius: 16, border: "1px solid rgba(124,58,237,0.1)", padding: 24, marginBottom: 14 }}>
              <h2 style={{ color: "#111", fontSize: 14, fontWeight: 700, margin: "0 0 20px" }}>Ingresos por mes</h2>
              <ResponsiveContainer width="100%" height={240}>
                <BarChart data={chartData}>
                  <CartesianGrid strokeDasharray="3 3" stroke="rgba(0,0,0,0.05)" />
                  <XAxis dataKey="mes" tick={{ fill: "#999", fontSize: 12 }} axisLine={false} tickLine={false} />
                  <YAxis tick={{ fill: "#999", fontSize: 11 }} axisLine={false} tickLine={false} tickFormatter={v => `$${(v/1000).toFixed(0)}k`} />
                  <Tooltip contentStyle={{ background: "#fff", border: "1px solid rgba(124,58,237,0.15)", borderRadius: 8, fontSize: 12 }} formatter={(v: any) => [fmt(v)]} />
                  <Bar dataKey="ingresos" fill="rgba(124,58,237,0.5)" radius={[4,4,0,0]} name="Proyectos" />
                  <Bar dataKey="paquetes" fill="#7c3aed" radius={[4,4,0,0]} name="Paquetes" />
                </BarChart>
              </ResponsiveContainer>
            </div>

            <div style={{ background: "#fff", borderRadius: 16, border: "1px solid rgba(124,58,237,0.1)", padding: 24 }}>
              <h2 style={{ color: "#111", fontSize: 14, fontWeight: 700, margin: "0 0 20px" }}>Tendencia total</h2>
              <ResponsiveContainer width="100%" height={200}>
                <LineChart data={chartData}>
                  <CartesianGrid strokeDasharray="3 3" stroke="rgba(0,0,0,0.05)" />
                  <XAxis dataKey="mes" tick={{ fill: "#999", fontSize: 12 }} axisLine={false} tickLine={false} />
                  <YAxis tick={{ fill: "#999", fontSize: 11 }} axisLine={false} tickLine={false} tickFormatter={v => `$${(v/1000).toFixed(0)}k`} />
                  <Tooltip contentStyle={{ background: "#fff", border: "1px solid rgba(124,58,237,0.15)", borderRadius: 8, fontSize: 12 }} formatter={(v: any) => [fmt(v)]} />
                  <Line type="monotone" dataKey="total" stroke="#7c3aed" strokeWidth={2} dot={{ fill: "#7c3aed", r: 4 }} name="Total" />
                </LineChart>
              </ResponsiveContainer>
            </div>
          </>
        )}
      </div>
    </div>
  );
}
