"use client";
import { useState, useEffect, useRef } from "react";
import { createClient } from "@/lib/supabase/client";
import { useRouter } from "next/navigation";
import Image from "next/image";

const TIPOS = ["Landing Page", "Sitio Corporativo", "Tienda Online", "Agencia", "Restaurante", "Inmobiliaria", "Consultorio", "Portafolio"];
const TEMAS = ["Moderno", "Corporativo", "Premium", "Minimalista"];

export default function AIBuilder() {
  const router = useRouter();
  const supabase = createClient();
  const fileRef = useRef<HTMLInputElement>(null);
  const [loading, setLoading] = useState(true);
  const [generating, setGenerating] = useState(false);
  const [saving, setSaving] = useState(false);
  const [uploadingLogo, setUploadingLogo] = useState(false);
  const [content, setContent] = useState<any>(null);
  const [websites, setWebsites] = useState<any[]>([]);
  const [tab, setTab] = useState<"generar" | "historial">("generar");
  const [logoUrl, setLogoUrl] = useState<string>("");
  const [form, setForm] = useState({
    project_name: "",
    prompt: "",
    website_type: "Landing Page",
    theme: "Moderno",
    primary_color: "#7c3aed",
    secondary_color: "#000000",
  });

  useEffect(() => {
    async function check() {
      const { data: { user } } = await supabase.auth.getUser();
      if (!user) { router.push("/auth/login"); return; }
      const { data: prof } = await supabase.from("profiles").select("role").eq("id", user.id).single();
      if (prof?.role !== "admin") { router.push("/dashboard/client"); return; }
      loadWebsites();
      setLoading(false);
    }
    check();
  }, []);

  async function loadWebsites() {
    const { data } = await supabase.from("generated_websites").select("*").order("created_at", { ascending: false });
    setWebsites(data ?? []);
  }

  async function handleLogoUpload(e: React.ChangeEvent<HTMLInputElement>) {
    const file = e.target.files?.[0];
    if (!file) return;
    setUploadingLogo(true);
    const ext = file.name.split(".").pop();
    const fileName = `logo-${Date.now()}.${ext}`;
    const { error } = await supabase.storage.from("logos").upload(fileName, file, { upsert: true });
    if (error) { alert("Error subiendo logo: " + error.message); setUploadingLogo(false); return; }
    const { data } = supabase.storage.from("logos").getPublicUrl(fileName);
    setLogoUrl(data.publicUrl);
    setUploadingLogo(false);
  }

  async function handleGenerate() {
    if (!form.prompt || !form.project_name) return;
    setGenerating(true);
    setContent(null);
    try {
      const res = await fetch("/api/ai-builder", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(form),
      });
      const data = await res.json();
      if (data.error) throw new Error(data.error);
      setContent(data.content);
    } catch (e: any) {
      alert("Error: " + e.message);
    } finally {
      setGenerating(false);
    }
  }

  async function handleSave() {
    if (!content) return;
    setSaving(true);
    const { data: { user } } = await supabase.auth.getUser();
    await supabase.from("generated_websites").insert({
      user_id: user?.id,
      project_name: form.project_name,
      prompt: form.prompt,
      website_type: form.website_type,
      theme: form.theme,
      primary_color: form.primary_color,
      secondary_color: form.secondary_color,
      generated_content: content,
      logo_url: logoUrl,
      status: "draft",
    });
    await loadWebsites();
    setSaving(false);
    alert("Sitio guardado correctamente");
  }

  async function handleDelete(id: string) {
    if (!confirm("Eliminar este sitio?")) return;
    await supabase.from("generated_websites").delete().eq("id", id);
    await loadWebsites();
  }

  if (loading) return (
    <div className="min-h-screen bg-white flex items-center justify-center">
      <div style={{ width: 40, height: 40, border: "3px solid #e9d5ff", borderTopColor: "#7c3aed", borderRadius: "50%", animation: "spin 0.8s linear infinite" }} />
      <style>{`@keyframes spin { to { transform: rotate(360deg); } }`}</style>
    </div>
  );

  const p = form.primary_color;

  return (
    <div className="min-h-screen bg-gray-50">
      <style>{`@keyframes spin { to { transform: rotate(360deg); } }`}</style>

      <header className="bg-white border-b border-gray-200 sticky top-0 z-50">
        <div className="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
          <div className="flex items-center gap-3">
            <Image src="/logo-dms.png" alt="DMS" width={120} height={38} />
            <span className="text-xs bg-purple-100 text-purple-700 font-semibold px-3 py-1 rounded-full">AI Builder</span>
          </div>
          <a href="/dashboard/admin" className="text-sm text-gray-500 hover:text-purple-600 transition-colors">Volver al admin</a>
        </div>
      </header>

      <main className="max-w-7xl mx-auto px-6 py-10">
        <div className="mb-8">
          <h1 className="text-3xl font-bold text-gray-900">AI Website Builder</h1>
          <p className="text-gray-500 mt-1">Genera sitios web profesionales con inteligencia artificial</p>
        </div>

        <div className="flex gap-2 mb-8 border-b border-gray-200">
          {(["generar", "historial"] as const).map(t => (
            <button key={t} onClick={() => setTab(t)} className="px-4 py-2 text-sm font-semibold capitalize transition-colors" style={{ borderBottom: tab === t ? `2px solid ${p}` : "2px solid transparent", color: tab === t ? p : "#6b7280" }}>
              {t === "generar" ? "Generar sitio" : "Mis sitios"}
            </button>
          ))}
        </div>

        {tab === "generar" && (
          <div className="grid lg:grid-cols-2 gap-8">
            <div className="space-y-6">

              {/* LOGO */}
              <div className="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
                <h2 className="text-lg font-bold text-gray-900 mb-4">Logo del cliente</h2>
                <div className="flex items-center gap-4">
                  {logoUrl ? (
                    <div className="relative w-24 h-24 rounded-xl border border-gray-200 overflow-hidden bg-gray-50 flex items-center justify-center">
                      <img src={logoUrl} alt="Logo" style={{ maxWidth: "100%", maxHeight: "100%", objectFit: "contain" }} />
                    </div>
                  ) : (
                    <div className="w-24 h-24 rounded-xl border-2 border-dashed border-gray-300 flex flex-col items-center justify-center gap-1 bg-gray-50">
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" strokeWidth="1.75"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                      <span className="text-xs text-gray-400">Sin logo</span>
                    </div>
                  )}
                  <div>
                    <button onClick={() => fileRef.current?.click()} disabled={uploadingLogo} className="text-sm px-4 py-2 rounded-lg font-semibold transition-colors border" style={{ borderColor: p, color: p }}>
                      {uploadingLogo ? "Subiendo..." : logoUrl ? "Cambiar logo" : "Subir logo"}
                    </button>
                    <p className="text-xs text-gray-400 mt-2">PNG, JPG o SVG. Max 2MB</p>
                    {logoUrl && (
                      <button onClick={() => setLogoUrl("")} className="text-xs text-red-400 hover:text-red-600 mt-1 block">Quitar logo</button>
                    )}
                  </div>
                  <input ref={fileRef} type="file" accept="image/*" style={{ display: "none" }} onChange={handleLogoUpload} />
                </div>
              </div>

              {/* CONFIG */}
              <div className="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
                <h2 className="text-lg font-bold text-gray-900 mb-4">Configuracion del sitio</h2>
                <div className="space-y-4">
                  <div>
                    <label className="block text-sm font-medium text-gray-700 mb-1">Nombre del proyecto *</label>
                    <input type="text" value={form.project_name} onChange={e => setForm({ ...form, project_name: e.target.value })} placeholder="Ej: Inmobiliaria El Dorado" className="w-full border border-gray-300 rounded-lg p-3 text-sm focus:outline-none focus:border-purple-600" />
                  </div>
                  <div>
                    <label className="block text-sm font-medium text-gray-700 mb-1">Tipo de sitio</label>
                    <select value={form.website_type} onChange={e => setForm({ ...form, website_type: e.target.value })} className="w-full border border-gray-300 rounded-lg p-3 text-sm focus:outline-none focus:border-purple-600">
                      {TIPOS.map(t => <option key={t} value={t}>{t}</option>)}
                    </select>
                  </div>
                  <div>
                    <label className="block text-sm font-medium text-gray-700 mb-1">Tema de diseno</label>
                    <div className="grid grid-cols-2 gap-2">
                      {TEMAS.map(t => (
                        <button key={t} onClick={() => setForm({ ...form, theme: t })} className="p-3 rounded-lg text-sm font-medium transition-all border" style={{ borderColor: form.theme === t ? p : "#e5e7eb", background: form.theme === t ? `${p}15` : "#fff", color: form.theme === t ? p : "#6b7280" }}>
                          {t}
                        </button>
                      ))}
                    </div>
                  </div>
                  <div className="grid grid-cols-2 gap-4">
                    <div>
                      <label className="block text-sm font-medium text-gray-700 mb-1">Color primario</label>
                      <div className="flex items-center gap-2">
                        <input type="color" value={form.primary_color} onChange={e => setForm({ ...form, primary_color: e.target.value })} className="w-10 h-10 rounded-lg border border-gray-300 cursor-pointer" />
                        <span className="text-sm text-gray-500">{form.primary_color}</span>
                      </div>
                    </div>
                    <div>
                      <label className="block text-sm font-medium text-gray-700 mb-1">Color secundario</label>
                      <div className="flex items-center gap-2">
                        <input type="color" value={form.secondary_color} onChange={e => setForm({ ...form, secondary_color: e.target.value })} className="w-10 h-10 rounded-lg border border-gray-300 cursor-pointer" />
                        <span className="text-sm text-gray-500">{form.secondary_color}</span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              {/* PROMPT */}
              <div className="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
                <h2 className="text-lg font-bold text-gray-900 mb-2">Prompt para la IA *</h2>
                <p className="text-xs text-gray-400 mb-3">Describe el negocio, servicios, colores, tono y cualquier detalle importante.</p>
                <textarea value={form.prompt} onChange={e => setForm({ ...form, prompt: e.target.value })} rows={6} placeholder="Ej: Crear landing page para una inmobiliaria en Pereira llamada El Dorado. Colores negro y dorado. Servicios: venta, arriendo y avaluos. Tono profesional y elegante." className="w-full border border-gray-300 rounded-lg p-3 text-sm focus:outline-none focus:border-purple-600 resize-none" />
                <button onClick={handleGenerate} disabled={generating || !form.prompt || !form.project_name} className="w-full mt-4 py-3 rounded-xl text-white font-bold text-sm transition-all disabled:opacity-50" style={{ background: generating ? "#9ca3af" : p }}>
                  {generating ? (
                    <span className="flex items-center justify-center gap-2">
                      <span style={{ width: 16, height: 16, border: "2px solid rgba(255,255,255,0.3)", borderTopColor: "#fff", borderRadius: "50%", display: "inline-block", animation: "spin 0.8s linear infinite" }} />
                      Generando sitio...
                    </span>
                  ) : "Generar Sitio"}
                </button>
              </div>
            </div>

            {/* PREVIEW */}
            <div className="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden sticky top-24" style={{ maxHeight: "calc(100vh - 120px)" }}>
              <div className="p-4 border-b border-gray-100 flex items-center justify-between">
                <h2 className="text-sm font-bold text-gray-700">Vista previa</h2>
                {content && (
                  <div className="flex gap-2">
                    <button onClick={handleSave} disabled={saving} className="text-xs px-3 py-1.5 rounded-lg text-white font-semibold" style={{ background: saving ? "#9ca3af" : "#10B981" }}>
                      {saving ? "Guardando..." : "Guardar"}
                    </button>
                  </div>
                )}
              </div>

              {!content && !generating && (
                <div className="flex flex-col items-center justify-center h-96 text-center px-8">
                  <div className="w-16 h-16 rounded-2xl mb-4 flex items-center justify-center" style={{ background: `${p}15` }}>
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke={p} strokeWidth="1.75"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                  </div>
                  <p className="text-gray-400 text-sm">Escribe un prompt y genera tu sitio web con IA</p>
                </div>
              )}

              {generating && (
                <div className="flex flex-col items-center justify-center h-96 text-center px-8">
                  <div style={{ width: 48, height: 48, border: `3px solid ${p}30`, borderTopColor: p, borderRadius: "50%", animation: "spin 0.8s linear infinite", marginBottom: 16 }} />
                  <p className="text-gray-500 text-sm font-medium">La IA esta generando tu sitio...</p>
                </div>
              )}

              {content && !generating && (
                <div className="overflow-y-auto" style={{ maxHeight: "calc(100vh - 200px)" }}>
                  {/* HERO */}
                  <div className="relative text-white text-center overflow-hidden" style={{ minHeight: 200, background: `linear-gradient(135deg, ${form.primary_color}, ${form.secondary_color || "#1a1a1a"})` }}>
                    <div className="relative z-10 p-8">
                      {logoUrl && <img src={logoUrl} alt="Logo" style={{ height: 48, objectFit: "contain", margin: "0 auto 1rem", display: "block", filter: "brightness(0) invert(1)" }} />}
                      <p className="text-xs uppercase tracking-widest mb-2 opacity-70">{form.website_type}</p>
                      <h1 className="text-xl font-bold mb-2">{content.hero?.titulo}</h1>
                      <p className="text-xs opacity-80 mb-4 max-w-xs mx-auto">{content.hero?.subtitulo}</p>
                      <div className="flex gap-2 justify-center flex-wrap">
                        <span className="px-3 py-1.5 bg-white text-xs font-bold rounded-lg" style={{ color: form.primary_color }}>{content.hero?.cta_principal}</span>
                        <span className="px-3 py-1.5 border border-white text-white text-xs font-bold rounded-lg">{content.hero?.cta_secundario}</span>
                      </div>
                    </div>
                  </div>

                  {/* SERVICIOS */}
                  {content.servicios && (
                    <div className="p-4 bg-gray-50">
                      <p className="text-xs font-bold uppercase tracking-widest mb-3 text-center" style={{ color: p }}>Servicios</p>
                      <div className="grid grid-cols-3 gap-2">
                        {content.servicios.map((s: any, i: number) => (
                          <div key={i} className="bg-white rounded-xl p-3 text-center shadow-sm">
                            <div className="w-7 h-7 rounded-lg mx-auto mb-2 flex items-center justify-center" style={{ background: `${p}15` }}>
                              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke={p} strokeWidth="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
                            </div>
                            <p className="text-xs font-bold text-gray-800 mb-1">{s.titulo}</p>
                            <p className="text-xs text-gray-500">{s.descripcion}</p>
                          </div>
                        ))}
                      </div>
                    </div>
                  )}

                  {/* BENEFICIOS */}
                  {content.beneficios && (
                    <div className="p-4">
                      <p className="text-xs font-bold uppercase tracking-widest mb-3 text-center" style={{ color: p }}>Por que elegirnos</p>
                      <div className="space-y-2">
                        {content.beneficios.map((b: any, i: number) => (
                          <div key={i} className="flex items-start gap-2 p-3 bg-gray-50 rounded-xl">
                            <div className="w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5" style={{ background: p }}>
                              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#fff" strokeWidth="3"><polyline points="20 6 9 17 4 12"/></svg>
                            </div>
                            <div>
                              <p className="text-xs font-bold text-gray-800">{b.titulo}</p>
                              <p className="text-xs text-gray-500">{b.descripcion}</p>
                            </div>
                          </div>
                        ))}
                      </div>
                    </div>
                  )}

                  {/* TESTIMONIOS */}
                  {content.testimonios && (
                    <div className="p-4 bg-gray-50">
                      <p className="text-xs font-bold uppercase tracking-widest mb-3 text-center" style={{ color: p }}>Testimonios</p>
                      <div className="space-y-2">
                        {content.testimonios.map((t: any, i: number) => (
                          <div key={i} className="bg-white rounded-xl p-3 shadow-sm">
                            <p className="text-xs text-gray-600 italic mb-2">"{t.texto}"</p>
                            <div className="flex items-center gap-2">
                              <div className="w-6 h-6 rounded-full flex items-center justify-center text-white text-xs font-bold" style={{ background: p }}>{t.nombre?.charAt(0)}</div>
                              <div>
                                <p className="text-xs font-bold text-gray-800">{t.nombre}</p>
                                <p className="text-xs text-gray-400">{t.cargo}</p>
                              </div>
                            </div>
                          </div>
                        ))}
                      </div>
                    </div>
                  )}

                  {/* FAQ */}
                  {content.faq && (
                    <div className="p-4">
                      <p className="text-xs font-bold uppercase tracking-widest mb-3 text-center" style={{ color: p }}>FAQ</p>
                      <div className="space-y-2">
                        {content.faq.map((f: any, i: number) => (
                          <div key={i} className="border border-gray-100 rounded-xl p-3">
                            <p className="text-xs font-bold text-gray-800 mb-1">{f.pregunta}</p>
                            <p className="text-xs text-gray-500">{f.respuesta}</p>
                          </div>
                        ))}
                      </div>
                    </div>
                  )}

                  {/* CONTACTO */}
                  {content.contacto && (
                    <div className="p-4 text-white" style={{ background: p }}>
                      <p className="text-xs font-bold uppercase tracking-widest mb-1 opacity-70">Contacto</p>
                      <h3 className="text-sm font-bold mb-1">{content.contacto.titulo}</h3>
                      <p className="text-xs opacity-80 mb-3">{content.contacto.descripcion}</p>
                      <div className="space-y-1 text-xs opacity-90">
                        {content.contacto.telefono && <p>Tel: {content.contacto.telefono}</p>}
                        {content.contacto.email && <p>{content.contacto.email}</p>}
                        {content.contacto.whatsapp && <p>WhatsApp: {content.contacto.whatsapp}</p>}
                      </div>
                    </div>
                  )}

                  {/* FOOTER */}
                  {content.footer && (
                    <div className="p-3 text-center" style={{ background: form.secondary_color || "#111" }}>
                      {logoUrl && <img src={logoUrl} alt="Logo" style={{ height: 28, objectFit: "contain", margin: "0 auto 0.5rem", display: "block", filter: "brightness(0) invert(1)" }} />}
                      <p className="text-xs font-bold text-white">{content.footer.nombre_empresa}</p>
                      <p className="text-xs text-gray-500 mt-1">{content.footer.copyright}</p>
                    </div>
                  )}
                </div>
              )}
            </div>
          </div>
        )}

        {/* HISTORIAL */}
        {tab === "historial" && (
          <div>
            {websites.length === 0 ? (
              <div className="bg-white rounded-2xl border border-gray-100 p-12 text-center">
                <p className="text-gray-400 mb-4">No has generado sitios aun.</p>
                <button onClick={() => setTab("generar")} className="text-sm px-6 py-2 rounded-lg text-white font-semibold" style={{ background: p }}>
                  Generar mi primer sitio
                </button>
              </div>
            ) : (
              <div className="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                {websites.map(w => (
                  <div key={w.id} className="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden hover:shadow-md transition-shadow">
                    <div className="h-24 flex items-center justify-center relative" style={{ background: `linear-gradient(135deg, ${w.primary_color || p}, ${w.secondary_color || "#1a1a1a"})` }}>
                      {w.logo_url ? (
                        <img src={w.logo_url} alt="Logo" style={{ height: 40, objectFit: "contain", filter: "brightness(0) invert(1)" }} />
                      ) : (
                        <p className="text-white font-bold text-lg">{w.project_name}</p>
                      )}
                    </div>
                    <div className="p-4">
                      <div className="flex items-center justify-between mb-2">
                        <span className="text-xs font-semibold px-2 py-1 rounded-full bg-purple-100 text-purple-700">{w.website_type}</span>
                        <span className="text-xs text-gray-400">{new Date(w.created_at).toLocaleDateString("es-CO")}</span>
                      </div>
                      <p className="text-sm font-bold text-gray-900 mb-1">{w.project_name}</p>
                      <p className="text-xs text-gray-500 mb-4 line-clamp-2">{w.prompt}</p>
                      <div className="flex gap-2">
                        <a href={`/demo/${w.id}`} target="_blank" className="flex-1 text-xs py-2 rounded-lg font-semibold text-center transition-colors" style={{ background: `${p}15`, color: p }}>
                          Ver demo
                        </a>
                        <button onClick={() => { navigator.clipboard.writeText(`${window.location.origin}/demo/${w.id}`); alert("Link copiado!"); }} className="flex-1 text-xs py-2 rounded-lg font-semibold bg-gray-100 text-gray-600 hover:bg-gray-200 transition-colors">
                          Copiar link
                        </button>
                        <button onClick={() => handleDelete(w.id)} className="text-xs py-2 px-3 rounded-lg font-semibold bg-red-50 text-red-500 hover:bg-red-100 transition-colors">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/></svg>
                        </button>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>
        )}
      </main>
    </div>
  );
}